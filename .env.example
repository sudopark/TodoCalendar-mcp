# 로컬 개발용 env 템플릿. 이 파일을 .env로 복사하고 실제 값으로 채워서 쓴다.
#
# 절대 실제 값을 이 파일에 넣고 커밋하지 말 것 — 이 레포는 public.
# .env / .env.local 등은 .gitignore로 차단되어 있음.
# 운영(Cloud Run) secret은 GitHub Actions Secrets → 배포 시 Cloud Run env vars로 주입.

# openAPI base URL
# 로컬: TodoCalendar-Functions emulator 주소
# 운영: 배포된 openAPI 엔드포인트
OPENAPI_BASE_URL=http://127.0.0.1:5001/<project-id>/us-central1/apiV2

# openAPI 서비스 인증 PAT (형식: <service>_<secret>, MVP는 mcp_<secret>)
# openAPI 측(TodoCalendar-Functions)과 동일 값 사용
OPENAPI_PAT_MCP=mcp_change_me

# 단일 시도 타임아웃 (ms). 기본 10000.
# Cloud Run 요청이 hang으로 매달리지 않도록 가드.
# OPENAPI_TIMEOUT_MS=10000

# 재시도 횟수 (총 시도 = 1 + RETRY_COUNT). 기본 2.
# GET/DELETE만 재시도 (멱등). POST/PUT/PATCH는 5xx여도 즉시 propagate.
# OPENAPI_RETRY_COUNT=2

# x-open-user-token HS256 서명 키
# aiFrontAPI / openAPI와 공유 (셋이 같은 값이어야 검증 통과)
SIGNING_SECRET=change_me_long_random_string

# confirm token HMAC 키 (delete tool 재호출 검증용)
CONFIRM_SECRET=change_me_long_random_string

# MCP server HTTP listen port (기본 3000)
PORT=3000

# auth pipeline — 'oauth' (기본, 외부 노출용) / 'dev' (로컬 stub)
# - oauth: Authorization: Bearer <RS256 JWT> 필수. 아래 MCP_OAUTH_ISSUER + MCP_CANONICAL_URI 필요.
# - dev: X-Dev-User-Id: <userId> 헤더 stub. mcp-inspector 등 로컬 클라이언트용.
AUTH_MODE=dev

# OAuth Authorization Server root URL — token iss 화이트리스트 + JWKS URL base + RFC 9728 authorization_servers
# 환경별 다른 값:
#   - production: https://api.todocalendar.com (Functions custom domain 확정 후)
#   - dev (Functions emulator): http://127.0.0.1:5001/<project-id>/<region>/api
# Functions #189와 동일 issuer 값 사용. JWKS는 <issuer>/.well-known/jwks.json 에서 fetch (5분 캐시).
MCP_OAUTH_ISSUER=

# 본 MCP server canonical URI — token aud 검증 + RFC 9728 resource 값
# trailing slash 미사용, path '/mcp' 포함. Functions OAUTH_CALENDAR_RESOURCE_URI 와 동일 값.
#   - dev: http://localhost:3000/mcp
#   - production: Cloud Run URL 확정 후 (예: https://<mcp-host>/mcp)
MCP_CANONICAL_URI=http://localhost:3000/mcp

# DNS rebinding 보호 — 이 값 미지정 시 protection 비활성 (로컬 dev 기본).
# 운영(Cloud Run) 배포 시 반드시 Cloud Run 호스트명을 콤마 구분으로 지정.
# 예: ALLOWED_HOSTS=todocalendar-mcp-xxx.a.run.app
# ALLOWED_HOSTS=
