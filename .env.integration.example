# Integration test용 env 템플릿. `.env.integration`으로 복사 후 채워 쓴다.
#
# 실행: `npm run test:integration`
# 전제: TodoCalendar-Functions emulator가 로컬에 떠 있어야 함.
#   (`cd ../TodoCalendar-Functions && firebase emulators:start`)
#
# 누락된 필수 env 또는 emulator 미기동 시 통합 테스트는 통째로 skip된다
# (CI에서 emulator 없이 실행해도 안전).

# openAPI emulator base URL. <project-id>는 Functions 레포의 .firebaserc/firebase.json 참조.
OPENAPI_BASE_URL=http://127.0.0.1:5001/<project-id>/us-central1/apiV2

# openAPI 서비스 인증 PAT — emulator는 functions/secrets/.env.test의 dummy hex secret을
# 주입하므로 그 값에 'mcp_' prefix를 붙여서 사용 (prod의 secrets/.env가 아님 — emulator는
# 의도적으로 prod secret과 분리된 dummy 값으로 동작).
OPENAPI_PAT_MCP=mcp_change_me

# x-open-user-token HS256 서명 키 — functions/secrets/.env.test의 SIGNING_SECRET 값 그대로
SIGNING_SECRET=change_me_long_random_string

# confirm token HMAC 키 — 본 레포 내부 검증용 (Functions와 무관, 아무 random 값)
CONFIRM_SECRET=change_me_long_random_string

# (선택) timeout/retry 조정 — emulator 응답이 느릴 때만
# OPENAPI_TIMEOUT_MS=10000
# OPENAPI_RETRY_COUNT=2
